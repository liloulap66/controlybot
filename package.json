{
  "name": "controlybot",
  "version": "1.0.6",
  "description": "Discord bot management application with Discord-like UI",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --publish always"
  },
  "keywords": [
    "discord",
    "bot",
    "electron",
    "manager"
  ],
  "author": "liloulap",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@discordjs/voice": "^0.19.0",
    "axios": "^1.6.0",
    "discord.js": "^14.14.1",
    "electron-log": "^4.4.8",
    "electron-updater": "^6.1.7",
    "ffmpeg-static": "^5.3.0",
    "opusscript": "^0.0.8",
    "prism-media": "^1.3.5"
  },
  "build": {
    "appId": "com.controlybot.app",
    "productName": "Controlybot",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "liloulap66",
      "repo": "controlybot"
    },
    "win": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "icon": "assets/icon.png"
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": [
        "AppImage"
      ]
    }
  }
}
